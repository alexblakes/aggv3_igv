rule catenate_affection:
    input:
        "data/interim/samples_gel_rd_affection.txt",
        "data/interim/samples_gms_rd_affection.txt",
    output:
        "data/interim/samples_cat_rd_affection.tsv",
    log:
        log_path("catenate_affection", workflow.snakefile),
    shell:
        """
        exec 2> >(tee {log} >&2)

        source src/utils.sh

        cat {input} \
        | tee >(_log "Unique status:\n" "$(cut -f 2 | sort | uniq -c)") \
        | tee >(_log "Output lines:" "$(wc -l)") \
        > {output}
        """


