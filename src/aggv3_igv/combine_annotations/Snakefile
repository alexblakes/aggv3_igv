rule catenate_dna_bams:
    input:
        "data/interim/samples_gel_dna_bams.tsv",
        "data/interim/samples_gms_dna_bams.tsv",
    output:
        "data/interim/samples_cat_dna_bams.tsv",
    log:
        log_path("catenate_dna_bams", workflow.snakefile),
    shell:
        """
        exec 2> >(tee {log} >&2)

        source src/utils.sh

        cat {input} \
        | tee >(_log "Assembly value_counts:\n" "$(cut -f 2 | sort | uniq -c)") \
        | tee >(_log "Unique participant IDs:" "$(cut -f 1 | sort -u | wc -l)") \
        | tee >(_log "Unique BAM paths:" "$(cut -f 3 | sort -u | wc -l)") \
        | tee >(_log "Output lines:" "$(wc -l)") \
        > {output}
        """


