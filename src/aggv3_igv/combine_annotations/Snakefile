from ab_utils.smk import log_path


configfile: "smk_config.yaml"


rule get_aggv3_samples:
    input:
        [],
    output:
        "data/final/aggv3_samples.txt",
    params:
        vcf = config["mnt_aggv3_bavcf"],
    shell:
        """
        #!/usr/bin/env bash

        set -eu

        source src/utils.sh

        bcftools query -l {params.vcf} \
        | tee >(_log "N samples:" "$(wc -l)") \
        > {output}
        """


